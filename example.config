# General Backup Configuration Template

BACKUP_NAME="my_app"
NAS_USER="username"
NAS_IP="192.168.x.x"

# Pre/Post Commands (Optional)
PRE_STOP_SERVICE=""    # systemd service to stop
PRE_APP_COMMAND=""     # remote command to run before sync
POST_APP_COMMAND=""    # remote command to run after sync
POST_START_SERVICE=""  # systemd service to start

# Database (Optional)
DB_NAME=""
DB_USER=""
DB_PASS=""

# Sources (Required)
SOURCE_DIRS=("/path/to/data1" "/path/to/data2")

# Retention
LOCAL_BACKUP_ROOT="/mnt/backup"
ROTATION_COUNT=5