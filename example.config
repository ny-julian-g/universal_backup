# =========================================================
# FULL FEATURE CONFIGURATION (Referenz-Vorlage)
# =========================================================

# 1. BASIS-IDENTIFIKATION
BACKUP_NAME="full_app_example"

# 2. VERBINDUNGSDATEN
NAS_USER="username"
NAS_IP="ip"

# 3. PRE-PROCESSING (Was passiert VOR dem Kopieren?)
# Stoppt einen Systemd-Dienst (z.B. eine Datenbank oder ein Game-Server)
PRE_STOP_SERVICE="example-service"

# Führt einen spezifischen Befehl aus (z.B. Maintenance Mode, Log-Rotation)
PRE_APP_COMMAND="sudo /usr/bin/prepare-script.sh"

# Datenbank-Zugangsdaten (löst den mysqldump aus)
DB_NAME="example_db"
DB_USER="admin"
DB_PASS="sicheres_passwort_123"

# 4. SYNC (Welche Verzeichnisse sollen gesichert werden?)
# Mehrere Verzeichnisse einfach in die Klammer schreiben
SOURCE_DIRS=(
    "/etc/myapp"
    "/var/lib/myapp/data"
    "/home/user/uploads"
)

# 5. POST-PROCESSING (Was passiert NACH dem Kopieren?)
# Führt einen Befehl aus (z.B. Maintenance Mode wieder OFF)
POST_APP_COMMAND="sudo /usr/bin/cleanup-script.sh"

# Startet den Systemd-Dienst wieder
POST_START_SERVICE="example-service"

# 6. STORAGE-MANAGEMENT
# Wo soll das Backup auf dem Laptop landen?
LOCAL_BACKUP_ROOT="/mnt/backup"

# Wie viele Versionen sollen behalten werden? (Rotation)
ROTATION_COUNT=10